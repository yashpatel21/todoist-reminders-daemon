# Required: Todoist API token (https://todoist.com/app/settings/integrations)
TODOIST_API_TOKEN=

# Poll interval in milliseconds (default: 60000)
# POLL_INTERVAL_MS=60000

# Advance only when now is within this window before the next occurrence (default: 5 minutes)
# ADVANCE_WINDOW_MS=300000

# Fallback IANA timezone when a task has no due.timezone (default: from GET /user tz_info)
# DEFAULT_TIMEZONE=America/Los_Angeles

# debug | info | warn | error
# LOG_LEVEL=info
