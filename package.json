{
	"name": "todoist-reminders-daemon",
	"version": "1.0.5",
	"description": "Background daemon that advances stale recurring timed Todoist tasks before the next occurrence.",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"test": "vitest run",
		"docker:build": "sh -c 'IMAGE=${npm_config_image:-yashpatel21/todoist-reminders-daemon}; TAG=${npm_config_tag:-latest}; docker build --platform linux/amd64 -t \"$IMAGE:$TAG\" .'",
		"docker:push": "sh -c 'IMAGE=${npm_config_image:-yashpatel21/todoist-reminders-daemon}; TAG=${npm_config_tag:-latest}; docker push \"$IMAGE:$TAG\"'",
		"docker:release": "sh -c 'IMAGE=${npm_config_image:-yashpatel21/todoist-reminders-daemon}; TAG=${npm_config_tag:-latest}; docker build --platform linux/amd64 -t \"$IMAGE:$TAG\" . && docker push \"$IMAGE:$TAG\"'"
	},
	"keywords": [
		"todoist",
		"daemon",
		"recurring"
	],
	"author": "",
	"license": "ISC",
	"type": "module",
	"engines": {
		"node": ">=20.18.1"
	},
	"dependencies": {
		"@doist/todoist-sdk": "^9.3.0",
		"dotenv": "^17.4.2",
		"luxon": "^3.7.2",
		"rrule": "^2.8.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/luxon": "^3.7.1",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	}
}
